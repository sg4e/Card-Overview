<Window x:Class="card_overview_wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:card_overview_wpf"
        mc:Ignorable="d"
        Title="Card Overview" Height="360" Width="420" Closing="Window_Closing" ResizeMode="NoResize"
        ShowInTaskbar="True" Loaded="Window_Loaded">
    <DockPanel>
        <Menu DockPanel.Dock="Top" Height="20">
            <MenuItem Header="Layout">
                <MenuItem Header="_Open" Click="MenuItem_Click" />
                <MenuItem Header="_Save" Click="MenuItem_Click_1" />
            </MenuItem>
            <MenuItem Header="Columns">
                <MenuItem Header="Add" Click="MenuItem_Click_2" />
                <MenuItem Header="Remove" Click="MenuItem_Click_4" />
            </MenuItem>
            <MenuItem Header="Rows">
                <MenuItem Header="Add" Click="MenuItem_Click_3" />
                <MenuItem Header="Remove" Click="MenuItem_Click_5" />
            </MenuItem>
            <MenuItem Header="About" Click="MenuItem_Click_7" />
            <MenuItem Header="Settings" Click="MenuItem_Click_6" />
        </Menu>
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Center" Text="URL" />
            <TextBox x:Name="teamUrlTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,8,0" MinWidth="220"
                     Text="https://hundo.maika.moe" VerticalContentAlignment="Center" />
            <Button x:Name="connectButton" Grid.Row="0" Grid.Column="2" MinWidth="80" Padding="8,2"
                    Content="Connect" Click="ConnectButton_Click" />

            <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,12,0,4"
                       Text="Teams" FontWeight="Bold" />
            <ListBox x:Name="teamListBox" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" MinHeight="160"
                     DisplayMemberPath="name" SelectionChanged="TeamListBox_SelectionChanged" />
            <Button x:Name="setTeamButton" Grid.Row="3" Grid.Column="2" Margin="0,8,0,0" MinWidth="80" Padding="8,2"
                    Content="Set Team" IsEnabled="False" Click="SetTeamButton_Click" />
            <TextBlock x:Name="teamStatusTextBlock" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,8,0,0"
                       TextWrapping="Wrap" Text="Connect to Team Hundo, choose a team, then set it to begin auto-tracking." />
        </Grid>
    </DockPanel>
</Window>
